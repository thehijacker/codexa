# Generate a secure secret with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

PORT=3000

# REQUIRED: Replace with a long random string before first run
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_64_chars

# Directory to store books, covers, fonts, and the SQLite database
DATA_DIR=./data

# Optional: restrict CORS to your domain (leave blank to allow same-origin only)
CORS_ORIGIN=
