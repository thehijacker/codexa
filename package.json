{
  "name": "codexa",
  "version": "1.0.0",
  "description": "EPUB web reader with OPDS browsing and KOReader sync support",
  "main": "server/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
